# =============================================================================
# sys-pkg-uninstall
# =============================================================================
# Uninstalls one or more packages using the appropriate package manager for the
# current OS. Skips packages that are not installed.
#
# USAGE:
#   sys-pkg-uninstall <package> [package...]
#
# EXAMPLE:
#   sys-pkg-uninstall git curl ripgrep
#
# SUPPORTED:
#   arch  — yay
#   macos — brew
#
# DEPENDENCIES:
#   sys-get-os, sys-pkg-check, logger.sh
# =============================================================================

LOG_LIB="$USER_LIB_DIR/bash/logger.sh"
source "$LOG_LIB" || { echo "FATAL: Could not load logger library '$LOG_LIB'!"; exit 1; }

usage() {
source "$0.help"
exit 1
}

declare -a PACKAGES

while [[ $# -gt 0 ]]; do
  case $1 in
    -h|--help)       usage ;;
    -v|--verbose)    LOG_LEVEL=8; shift ;;
    -f|--file)       PACKAGE_FILE=$2; shift 2 ;;
    *)               PACKAGES+=($1); shift ;;
  esac
done

OS=$(sys-get-os)

get-uninstall-cmd() {

  case "$OS" in
    arch)  echo "yay -R --noconfirm" ;;
    macos) echo "brew uninstall" ;;
    fedora) fatal "Not implemented yet!" ;;
    ubuntu) echo "sudo apt-get install -y" ;;
  esac
}

# Load packages from the specified file
if [[ -n "$PACKAGE_FILE" && -f "$PACKAGE_FILE" ]]; then
  debug "Loading packages from '$PACKAGE_FILE'..."
  mapfile -t PACKAGES < <(sed -e 's/#.*//g' -e '/^$/d' $PACKAGE_FILE)
fi

PACKAGE_COUNT=${#PACKAGES[@]}
[ $PACKAGE_COUNT -eq 0 ] && error "No packages specified!" && usage
debug "'$OS': $PACKAGE_COUNT packages to uninstall."

declare -a PACKAGES_TO_UNINSTALL

for package in "${PACKAGES[@]}"; do
  # Build an array of packages that DO NOT exist on the system
  if ! sys-pkg-check "$package" "$OS" ; then
    debug "Package $(bold_green $package) not installed. Nothing to do."
  else
    PACKAGES_TO_UNINSTALL+=($package)
  fi
done

# Build install command based on OS
cmd=$(get-uninstall-cmd)
$cmd "${PACKAGES_TO_UNINSTALL[@]}" 


