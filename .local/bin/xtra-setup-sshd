sudo pacman -S --noconfirm --needed openssh

sudo cp /etc/ssh/sshd_config /etc/ssh/sshd_config.bak

config_file=/etc/ssh/sshd_config
sudo sed -i 's/^#\(\s*AuthorizedKeysFile.*\)/\1/' "$config_file"
sudo sed -i 's/^#\(\s*PasswordAuthentication.*\)/\1/' "$config_file"
sudo sed -i 's/^#\(\s*PermitRootLogin.*\)/\1/' "$config_file"
sudo sed -i 's/^#\(\s*PubkeyAuthentication.*\)/\1/' "$config_file"
# sudo sed -i 's/#PermitRootLogin no/PermitRootLogin no/' $config_file
# sudo sed -i 's/#PubkeyAuthentication yes/PermitRootLogin yes/' $config_file
# sudo sed -i 's/#AuthorizedKeysFile .ssh\/authorized_keys/PermitRootLogin yes/' $config_file
# config=$(cat << EOF 
