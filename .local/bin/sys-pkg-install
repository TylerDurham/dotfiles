# ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚ēó  ‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó       ‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚Ėą‚ēó   ‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚ēó     ‚Ėą‚Ėą‚ēó
# ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēĎ ‚Ėą‚Ėą‚ēĒ‚ēĚ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēź‚ēź‚ēĚ       ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚Ėą‚Ėą‚ēó  ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēź‚ēź‚ēĚ‚ēö‚ēź‚ēź‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēĚ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēĎ     ‚Ėą‚Ėą‚ēĎ
# ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ ‚Ėą‚Ėą‚ēĎ  ‚Ėą‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĒ‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó   ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĎ     ‚Ėą‚Ėą‚ēĎ
# ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēź‚ēĚ ‚Ėą‚Ėą‚ēĒ‚ēź‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēĚ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĎ‚ēö‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēĎ‚ēö‚ēź‚ēź‚ēź‚ēź‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĎ     ‚Ėą‚Ėą‚ēĎ
# ‚Ėą‚Ėą‚ēĎ     ‚Ėą‚Ėą‚ēĎ  ‚Ėą‚Ėą‚ēó‚ēö‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ      ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĎ ‚ēö‚Ėą‚Ėą‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ  ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó
# ‚ēö‚ēź‚ēĚ     ‚ēö‚ēź‚ēĚ  ‚ēö‚ēź‚ēĚ ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ       ‚ēö‚ēź‚ēĚ‚ēö‚ēź‚ēĚ  ‚ēö‚ēź‚ēź‚ēź‚ēĚ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ   ‚ēö‚ēź‚ēĚ   ‚ēö‚ēź‚ēĚ  ‚ēö‚ēź‚ēĚ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ
# =============================================================================
# sys-pkg-install
# =============================================================================
# Installs one or more packages using the appropriate package manager for the
# current OS. Skips packages that are already installed.
#
# USAGE:
#   sys-pkg-install <package> [package...]
#
# EXAMPLE:
#   sys-pkg-install git curl ripgrep
#
# SUPPORTED:
#   arch   ‚ÄĒ yay
#   macos  ‚ÄĒ brew
#   ubuntu ‚ÄĒ apt-get
#
# DEPENDENCIES:
#   sys-get-os, sys-pkg-check, logger.sh
# =============================================================================

LOG_LIB="$USER_LIB_DIR/bash/logger.sh"
source "$LOG_LIB" || { echo "FATAL: Could not load logger library '$LOG_LIB'!"; exit 1; }

usage() {
source "$0.help"
exit 1
}

declare -a PACKAGES

while [[ $# -gt 0 ]]; do
  case $1 in
    -h|--help)       usage ;;
    -v|--verbose)    LOG_LEVEL=8; shift ;;
    -f|--file)       PACKAGE_FILE=$2; shift 2 ;;
    *)               PACKAGES+=($1); shift ;;
  esac
done

OS=$(sys-get-os)

get-install-cmd() {

  case "$OS" in
    arch)  echo "yay -S --needed --quiet --noconfirm" ;;
    macos) echo "brew install" ;;
    fedora) fatal "Not implemented yet!" ;;
    ubuntu) echo "sudo apt-get install -y" ;;
  esac
}

# Load packages from the specified file
if [[ -n "$PACKAGE_FILE" && -f "$PACKAGE_FILE" ]]; then
  debug "Loading packages from '$PACKAGE_FILE'..."
  mapfile -t PACKAGES < <(sed -e 's/#.*//g' -e '/^$/d' $PACKAGE_FILE)
fi

PACKAGE_COUNT=${#PACKAGES[@]}
[ $PACKAGE_COUNT -eq 0 ] && error "No packages specified!" && usage
debug "'$OS': $PACKAGE_COUNT packages to install."

declare -a PACKAGES_TO_INSTALL

for package in "${PACKAGES[@]}"; do
  # Build an array of packages that DO NOT exist on the system
  if sys-pkg-check "$package" "$OS" ; then
    debug "Package $(bold_green $package) already installed. Nothing to do."
  else
    PACKAGES_TO_INSTALL+=($package)
  fi
done

# Build install command based on OS
cmd=$(get-install-cmd)
$cmd "${PACKAGES_TO_INSTALL[@]}" 


