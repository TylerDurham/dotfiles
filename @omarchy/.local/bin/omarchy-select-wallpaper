set_wallpaper(){
    # symlink the selected background into the omarchy dir
    ln -sf "$HOME/.config/omarchy/current/backgrounds/$1" ~/.config/omarchy/current/background

    # restart swaybg and pass in the path to the current background
    pkill -x swaybg
    setsid swaybg -i ~/.config/omarchy/current/background -m fill >/dev/null 2>&2 &
}

# Function to list images and format for wofi
list_current_theme_wallpapers() {
    ls -A "$HOME/.config/omarchy/current/backgrounds/" | while read -r img; do
        full_path="$HOME/.config/omarchy/current/backgrounds/$img"
        # echo $full_path
        if [[ -f "$full_path" ]]; then 
          echo "img:$full_path:text:$(basename "$img")"
        fi
    done
}

# DEBUG
# list_current_theme_wallpapers && exit 0

wallpaper=$(list_current_theme_wallpapers |  flock --nonblock /tmp/.wofi.lock -c "wofi -dmenu --width 60% --height 70% --allow-images -p 'Hyprland Wallpaper' -O alphabetical  --style=\"$HOME/.local/share/omarchy/default/wofi/select.css\""
)

if [[ -z "$wallpaper" ]]; then 
  echo "Nothing selected."
  exit 0
fi

# grab everything after the last ":"
wallpaper=${wallpaper##*:}

# set the new wallpaper
set_wallpaper $wallpaper


