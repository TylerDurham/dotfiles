help_text=$(cat <<EOF
$(bold USAGE:) 

  $(bold $(basename $0)) <package> [<package>] [-h] [-v] [-f <path-to-file>]

$(bold DESCRIPTION:)

  Installs one or more packages. A list of packages can be specified in a file using the '-f' argument.

$(bold OPTIONS:)

  -h, --help       Show this help message
  -v, --verbose    Enable verbose output
  -f, --filename   Path to a file with a list of packages
EOF
)

echo "$help_text"
