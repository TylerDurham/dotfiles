// -*- mode: jsonc -*- //
{
    "position": "top",
    "spacing": 4,
    "include": [
      "~/.config/waybar/modules/check-updates.jsonc",
      "~/.config/waybar/modules/system.jsonc",
      "~/.config/waybar/modules/workspaces.jsonc"
    ],
    "modules-left": [
      "hyprland/workspaces"
    ],
    "modules-center": [
      "hyprland/window",
      "custom/check-updates-dnf"
    ],
    "modules-right": [
      "cpu",
      "memory",
      "clock"
    ]
} 
